PORT=5000
NODE_ENV=development

# Stripe secret key (backend only; get from https://dashboard.stripe.com/apikeys)
stripe_secret_key=sk_test_your_secret_key_here

# Stripe Price IDs (get from Stripe dashboard -> Products -> Pricing)
# Create products and prices in Stripe dashboard, then copy the price IDs here
STRIPE_PRICE_STARTER=price_your_starter_price_id
STRIPE_PRICE_ENTREPRENEUR=price_your_entrepreneur_price_id
STRIPE_PRICE_PRO=price_your_pro_price_id

# Frontend URL for redirects (update this for production)
FRONTEND_URL=http://localhost:5173
