# Stripe Public Key (get from https://dashboard.stripe.com/apikeys)
# IMPORTANT: Add your real Stripe publishable key here for Vercel
VITE_STRIPE_PUBLIC_KEY=pk_test_your_publishable_key_here

# Backend API URL
# For local development: http://localhost:5000
# For Vercel deployment: /_/backend
VITE_API_URL=http://localhost:5000

# Stripe Price IDs (must match backend environment variables exactly)
# These are used for the checkout form dropdown
VITE_STRIPE_PRICE_STARTER=price_1TiLHo2Yw7BUASOy1HENYyVc
VITE_STRIPE_PRICE_ENTREPRENEUR=price_1TiLEq2Yw7BUASOyKr7cpevz
VITE_STRIPE_PRICE_PRO=price_1TiLHI2Yw7BUASOygPrCe1M2
